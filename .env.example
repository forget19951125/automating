# ===== 币安 API 配置 =====
# 正式网 API Key（从 https://www.binance.com/zh-CN/my/settings/api-management 获取）
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here

# 是否使用测试网（true=测试网, false=正式网）
# 测试网地址: https://testnet.binancefuture.com
USE_TESTNET=true

# ===== 策略参数（完全对应 Pine Script V37）=====

# 策略初始资金（仅用于首次启动时初始化回撤历史基准）
# 实际运行时，系统会实时读取账户余额作为 currEq
INIT_CAPITAL=15000

# 单笔风险百分比（对应 Pine Script: baseRisk = 3.0）
# tradeQty = (currEq * baseRisk/100) / stopDist
BASE_RISK=3.0

# 最大持仓K线数（对应 Pine Script: maxHoldBars = 100）
MAX_HOLD_BARS=100

# 最大回撤百分比（对应 Pine Script: drawdown < 14.0）
MAX_DRAWDOWN=14.0

# ===== 仓位设置 =====

# 杠杆倍数（4倍，名义仓位 = 账户余额 × 4）
LEVERAGE=4

# 名义仓位倍数（账户余额 × 此倍数 = 名义仓位）
# 例：账户余额 3500 USDT → 名义仓位 = 3500 × 4 = 14000 USDT
NOMINAL_MULTIPLIER=4.0

# ===== Web 服务 =====
WEB_PORT=8080
